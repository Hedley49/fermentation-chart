set xdata time
set timefmt "%m:%d:%H:%M:%S"
set format x "%M:%S\n%d/%H"
set yrange [60:86]
plot "x1.txt" using 1:2 with lines linewidth 2 lc rgb "violet" title "ENV", \
     "x1.txt" using 1:3:5 with lines linewidth 2 lc rgb variable title "BEER", \
     "x1.txt" using 1:4 with lines dashtype 2 lc rgb "black" title "68.0 F"
# below line will keep zoom function alive.
pause mouse close
 
